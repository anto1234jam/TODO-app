generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model UserDetail {
  id       Int    @id @default(autoincrement())
  username String
  email    String @unique
  password String

  @@map("userdetail")
}

model UserTask {
  id     Int    @id @default(autoincrement())
  task   String
  status Int
  email  String

  @@map("usertask")
}